# Supabase (https://supabase.com/dashboard → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use "anon" legacy public key, or the new publishable key (either works with this app)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Used for absolute Open Graph URLs in production (optional in dev)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
